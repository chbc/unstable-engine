directional_light:
  directional_light: 1
  Components:
    - TransformComponent:
        Enabled: 1
        Position: [0,2,0]
        Rotation: [120,45,0]
        Scale: [1,1,1]
    - DirectionalLightComponent:
        Enabled: 1
        Color: [0.6,0.6,0.6]
Cube:
  Cube: 1
  Components:
    - TransformComponent:
        Enabled: 1
        Position: [0,0,0]
        Rotation: [0,0,0]
        Scale: [1,1,1]
    - MeshComponent:
        Enabled: 1
        Mesh:
          FilePath: engine\media\meshes\Cube.mesh
          MeshName: Cube
        Material: engine\media\materials\DefaultMaterial.mat
    - BoxColliderComponent:
        Enabled: 1
        Blocking: 1
        Center: [0,0,0]
        Half Extents: [0.5,0.50000006,0.50000006]
_main_camera:
  _main_camera: 1
  Components:
    - TransformComponent:
        Enabled: 1
        Position: [0,2,5]
        Rotation: [0,0,0]
        Scale: [1,1,1]
    - CameraComponent:
        Enabled: 1
        Perspective: 1
        Main Camera: 0
        FOV: 70
